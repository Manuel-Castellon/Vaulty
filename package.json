{
  "name": "vaulty",
  "private": true,
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "scripts": {
    "web": "npm run dev --workspace=packages/web",
    "mobile": "npm run start --workspace=packages/mobile",
    "backend:deploy": "npm run deploy --workspace=packages/backend",
    "backend:dev": "npm run dev --workspace=packages/backend"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "expo-font": "~12.0.10",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1"
  },
  "dependencies": {
    "@react-native-community/cli-server-api": "^13.6.9",
    "expo-constants": "~16.0.2",
    "expo-dev-client": "~4.0.29",
    "expo-linking": "~6.3.1",
    "react-native-screens": "~3.31.1"
  }
}
