{
  "name": "@coupon/backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "sam local start-api --env-vars env.json",
    "build": "node scripts/bundle.mjs && DIST_DIR=$(pwd)/dist sam build",
    "deploy": "sam deploy --guided",
    "deploy:ci": "sam deploy",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:live": "RUN_LIVE_GEMINI_TESTS=1 jest src/functions/ai/__tests__/extract.live.test.js --runInBand",
    "test:vouchers": "npx ts-node --project tsconfig.json scripts/runVoucherTests.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "uuid": "^9.0.0",
    "jimp": "^0.22.12",
    "jsqr": "^1.4.0"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@coupon/shared": "*",
    "@types/aws-lambda": "^8.10.0",
    "@types/uuid": "^9.0.0",
    "aws-sam-local": "*",
    "esbuild": "^0.21.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
